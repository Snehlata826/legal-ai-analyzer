# ══════════════════════════════════════════════════════
#  Legal AI Analyzer — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control!
# ══════════════════════════════════════════════════════

# ── Groq API (REQUIRED) ──────────────────────────────
# Free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Groq model (optional) ────────────────────────────
# Available free models:
#   llama3-8b-8192          ← fastest, good quality (default)
#   llama-3.1-8b-instant    ← alternative fast model
#   mixtral-8x7b-32768      ← better for long documents
GROQ_DEFAULT_MODEL=llama3-8b-8192
GROQ_MAX_TOKENS=500
GROQ_TEMPERATURE=0.3

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=false

# ── CORS — comma-separated allowed frontend origins ──
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Document processing limits ───────────────────────
MAX_UPLOAD_SIZE_MB=10
MAX_CLAUSES_PER_DOC=50
CLAUSE_MIN_LENGTH=20

# ── Storage ──────────────────────────────────────────
REPORT_OUTPUT_DIR=temp_reports

# ── Security / Rate limiting ──────────────────────────────────────
# Max requests per IP per minute (all endpoints)
RATE_LIMIT_GLOBAL=60
# Max upload requests per IP per minute (expensive endpoint)
RATE_LIMIT_UPLOAD=5
# Trusted reverse-proxy IPs — comma-separated (skip rate limit for these)
TRUSTED_PROXIES=127.0.0.1,::1
